# Backend environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# ── Supabase (primary datastore + auth) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── TMDB (used by the data-fetch scripts only) ───────────────────────────────
TMDB_API_KEY=your-tmdb-key

# ── OpenAI (cold-start LLM — used by the worker) ─────────────────────────────
OPENAI_API_KEY=your-openai-key

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# Local/non-docker default. Under docker compose this is overridden automatically
# to amqp://guest:guest@rabbitmq:5672/ (the broker service name).
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── CORS — comma-separated list of allowed frontend origins ──────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Load testing — bypass real LLM calls (worker) ────────────────────────────
MOCK_OPENAI=false
MOCK_OPENAI_DELAY_MS=2000
