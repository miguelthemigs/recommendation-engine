# Frontend environment template. Copy to `.env` and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Backend API base URL (injected at build time per deployment target).
VITE_API_URL=http://localhost:8000

# Supabase (browser client uses the anon key — safe to expose).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
